    {
      "customFieldId": "default_value_custom",
      "fieldType": 20,
      "iconSvgUrl": "",
      "name": "默认值自定义",
      "externalData": {
        "formulaTemplate": "[{$ sourceField.name $}]"
      },
      "uiSchema": {
        "fieldsConfigEditor": {
          "component": "openFieldMetaEditor",
