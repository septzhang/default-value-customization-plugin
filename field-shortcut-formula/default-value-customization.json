                  "validator": {
                    "required": true
                  }
                }
              ]
            }
          }
        }
      },
      "disableNativeCellOperate": true,
      "showNativeFieldEditor": false,
      "presetFieldConfig": {
        "fieldProperty": {
          "dataType": {
            "type": 1
          }
        }
      }
    }
  ]
